# Em dev: copie para `.env`. Em produção (Railway/Vercel) defina no painel do
# serviço — não commite o `.env` real. Ver DEPLOY.md para o mapa por serviço.

# ---- PostgreSQL (Docker Compose) ----
POSTGRES_USER=kerno
POSTGRES_PASSWORD=kerno
POSTGRES_DB=kerno

# ---- Prisma / App database connection ----
DATABASE_URL="postgresql://kerno:kerno@localhost:5432/kerno?schema=public"

# ---- Auth (Fase 1 — gerar com: openssl rand -base64 32) ----
AUTH_SECRET="change-me"

# ---- App (web) ----
PORT=3000
HOST=localhost
# URL pública do web (NextAuth v5). Local: http://localhost:3000
# Produção: a URL do serviço web (ex.: https://kerno-web.up.railway.app)
AUTH_URL="http://localhost:3000"

# ---- API (backend NestJS) ----
API_PORT=3333
WEB_ORIGIN="http://localhost:3000"

# URL da API usada pelo web (BFF) para falar com o backend
API_URL="http://localhost:3333/api"
