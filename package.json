{
  "name": "kerno",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @kerno/db generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @kerno/db migrate",
    "db:push": "dotenv -e .env -- pnpm --filter @kerno/db push",
    "db:studio": "dotenv -e .env -- pnpm --filter @kerno/db studio",
    "db:seed": "dotenv -e .env -- pnpm --filter @kerno/db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
