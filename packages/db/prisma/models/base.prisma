// Núcleo — identidade + contexto (workspace / membership).
// generator + datasource vivem aqui (precisam estar em um único arquivo).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  avatar       String?
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaces          WorkspaceUser[]
  messages            Message[]
  directConversations DirectParticipant[]
  cards               Card[]
}

// Workspace é o único nível de contexto: dono de boards, canais, cycles, DMs e
// eventos. (Antes havia Workspace→Project; a camada Project foi removida e o
// projeto foi promovido a workspace.)
model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  // Identidade dos cards: exibidos como `key`-`number` (ex.: KERN-123). O contador
  // é incrementado transacionalmente ao criar cada card (numeração por workspace).
  key         String   @default("")
  cardCounter Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users               WorkspaceUser[]
  boards              Board[]
  cycles              Cycle[]
  channels            Channel[]
  directConversations DirectConversation[]
  events              Event[]
}

model WorkspaceUser {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  ADMIN
  MEMBER
  VIEWER
}
