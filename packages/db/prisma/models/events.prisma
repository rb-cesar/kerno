// Event log — auditoria + integração entre hubs (preenchido pelo dispatcher).

model Event {
  id          String   @id @default(cuid())
  type        String // "card:created", "card:moved", "message:sent", ...
  payload     Json
  workspaceId String
  userId      String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
}
