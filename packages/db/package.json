{
  "name": "@kerno/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "gather": "node prisma/gather.mjs",
    "generate": "node prisma/gather.mjs && prisma generate",
    "migrate": "node prisma/gather.mjs && prisma migrate dev",
    "push": "node prisma/gather.mjs && prisma db push",
    "studio": "node prisma/gather.mjs && prisma studio",
    "seed": "tsx prisma/seed.ts",
    "build": "node prisma/gather.mjs && prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
