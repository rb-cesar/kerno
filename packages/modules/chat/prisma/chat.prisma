// Hub Chat — dono das tabelas Channel / Message / DirectConversation.

model Channel {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([workspaceId])
}

// Conversa privada (DM) entre membros de um mesmo workspace. `pairKey` é a lista
// ordenada dos userIds participantes, garantindo uma única conversa por par
// dentro do workspace (upsert determinístico).
model DirectConversation {
  id          String   @id @default(cuid())
  workspaceId String
  pairKey     String
  createdAt   DateTime @default(now())

  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  participants DirectParticipant[]
  messages     Message[]

  @@unique([workspaceId, pairKey])
  @@index([workspaceId])
}

model DirectParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

// Uma mensagem pertence a um Channel OU a uma DirectConversation (exatamente um
// dos dois é preenchido).
model Message {
  id             String   @id @default(cuid())
  content        String
  channelId      String?
  conversationId String?
  userId         String?
  replyToId      String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel      Channel?            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversation DirectConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  replyTo      Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]           @relation("MessageReplies")
  reactions    Reaction[]

  @@index([channelId])
  @@index([conversationId])
  @@index([replyToId])
}

// Reação (emoji) de um usuário a uma mensagem. `userId` é escalar (sem FK p/ User,
// que vive no núcleo) — uma reação por (mensagem, usuário, emoji).
model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}
