// Hub Chat — dono das tabelas Channel / Message / DirectConversation.

model Channel {
  id        String   @id @default(cuid())
  name      String
  projectId String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([projectId])
}

// Conversa privada (DM) entre membros de um mesmo projeto. `pairKey` é a lista
// ordenada dos userIds participantes, garantindo uma única conversa por par
// dentro do projeto (upsert determinístico).
model DirectConversation {
  id        String   @id @default(cuid())
  projectId String
  pairKey   String
  createdAt DateTime @default(now())

  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  participants DirectParticipant[]
  messages     Message[]

  @@unique([projectId, pairKey])
  @@index([projectId])
}

model DirectParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

// Uma mensagem pertence a um Channel OU a uma DirectConversation (exatamente um
// dos dois é preenchido).
model Message {
  id             String   @id @default(cuid())
  content        String
  channelId      String?
  conversationId String?
  userId         String?
  replyToId      String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel      Channel?            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversation DirectConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  replyTo      Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]           @relation("MessageReplies")

  @@index([channelId])
  @@index([conversationId])
  @@index([replyToId])
}
